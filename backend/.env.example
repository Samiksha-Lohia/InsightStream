# Server Configuration
PORT=3000

# Database Configuration
# MongoDB Connection String (e.g., mongodb://localhost:27017/insightstream or MongoDB Atlas URI)
MONGODB_URL=mongodb://127.0.0.1:27017/insightstream

# Cache & Message Broker (Redis) Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_URL=redis://127.0.0.1:6379

# Third-Party AI Service Integration
# Get your API key from the Groq Console (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Security
# Random high-entropy secret key for signing JWTs
JWT_SECRET=your_jwt_secret_here
